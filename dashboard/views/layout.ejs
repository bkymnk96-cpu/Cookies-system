<!doctype html><html lang="<%= lang %>" dir="<%= lang==='ar'?'rtl':'ltr' %>"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>ZEUS Dashboard</title><link rel="stylesheet" href="/dashboard/public/css/style.css"><script defer src="/dashboard/public/js/main.js"></script></head><body><button class="mobile-menu" data-sidebar>☰</button><aside class="sidebar"><div class="brand"><div class="logo">Z</div><div><b>ZEUS</b><small><span class="dot"></span> Online</small></div></div><% if (guild) { %><div class="guild-pill"><span><%= guild.name %></span><a href="/guilds">تغيير</a></div><% } %><% const id=guild&&guild.id; const groups=[['GENERAL',[['','Dashboard','grid'],['commands','Commands','terminal'],['settings','Server Settings','cog']]],['SYSTEMS',[['welcome','Welcome'],['tickets','Tickets'],['applications','Applications'],['suggestions','Suggestions'],['feedback','Feedback'],['giveaways','Giveaways'],['autoReply','Auto Reply'],['autoLine','Auto Line'],['tax','Tax']]],['SECURITY',[['protection','Protection'],['logs','Logs']]],['ACTIVITY',[['activity','Activity'],['adminPoints','Admin Points']]],['BROADCAST',[['broadcast','Broadcast']]]]; %><nav><% if(id) groups.forEach(gp=>{ %><h4><%= gp[0] %></h4><% gp[1].forEach(l=>{ const href='/guild/'+id+(l[0]?'/'+l[0]:''); %><a class="nav <%= (locals.module===l[0]||(!l[0]&& !locals.module && !locals.commands))?'active':'' %>" href="<%= href %>"><span>⬡</span><%= l[1] %></a><% })}) %><% } %></nav><div class="side-foot"><button id="themeToggle">🌙</button><select id="lang"><option value="ar">العربية</option><option value="en">English</option></select><a href="/logout">Logout</a></div></aside><main class="content"><%- body %></main><div id="toast"></div></body></html>
