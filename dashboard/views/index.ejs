<% const cards=[['Ping',overview.stats.ping+'ms','زمن استجابة Discord'],['Uptime',Math.floor(overview.stats.uptime/3600)+'h','مدة التشغيل'],['Servers',overview.stats.guilds,'السيرفرات'],['Members',overview.stats.members,'أعضاء السيرفر'],['Commands',overview.stats.commands,'أوامر ZEUS'],['Enabled Systems',overview.stats.enabledSystems,'أنظمة مفعلة']]; %><%- include('layout',{body:`<header class="page"><p>ZEUS / Dashboard</p><h1>${overview.guild?.name||'Server Dashboard'}</h1><span>لوحة مرتبطة بالبوت و MongoDB لكل Guild ID.</span></header><section class="stats">${cards.map(c=>`<article class="stat"><i>✦</i><b>${c[1]}</b><h3>${c[0]}</h3><p>${c[2]}</p></article>`).join('')}</section><h2>حالة الأنظمة</h2><section class="module-grid">${Object.entries(overview.configs).map(([k,v])=>`<article class="module-card"><div><h3>${k}</h3><p>${v.enabled||v.systems?'Enabled':'Disabled'}</p></div><a href="/guild/${overview.guild.id}/${k}">إعدادات</a></article>`).join('')}</section>`}) %>
