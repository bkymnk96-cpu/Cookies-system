<% const cats=[...new Set(commands.map(c=>c.category))]; const body=`<header class="page"><p>ZEUS / Commands</p><h1>إدارة الأوامر</h1><span>كل أمر مرتبط بإعدادات السيرفر الحالي ويتم التحقق منه قبل التنفيذ.</span></header><section class="toolbar"><input id="search" placeholder="Search command..."><select id="cat"><option value="">All categories</option>${cats.map(c=>`<option>${c}</option>`).join('')}</select><button data-enable-all>Enable All</button><button data-disable-all>Disable All</button></section><section class="stats"><article class="stat"><b>${commands.length}</b><h3>Total</h3></article><article class="stat"><b id="enabledCount">0</b><h3>Enabled</h3></article><article class="stat"><b id="disabledCount">0</b><h3>Disabled</h3></article><article class="stat"><b>${Object.values(settings).filter(s=>s.aliases&&s.aliases.length).length}</b><h3>Aliases</h3></article></section><form id="commandsForm" class="command-grid">${commands.map(c=>{const s=Object.assign({enabled:true,aliases:[],cooldown:0,allowedRoles:[],deniedRoles:[],allowedChannels:[],deniedChannels:[]},settings[c.name]||{}); return `<article class="card command" data-name="${c.name}" data-cat="${c.category}"><div class="row"><div><h3>/${c.name}</h3><p>${c.description}</p><small>${c.category} • cooldown ${s.cooldown}s</small></div><label class="switch"><input name="${c.name}.enabled" type="checkbox" ${s.enabled?'checked':''}><span></span></label></div><details><summary>Settings</summary><label>Aliases<input name="${c.name}.aliases" value="${s.aliases.join(', ')}"></label><label>Cooldown<input type="number" name="${c.name}.cooldown" value="${s.cooldown}"></label><label>Allowed Roles<select multiple name="${c.name}.allowedRoles">${resources.roles.map(r=>`<option value="${r.id}" ${s.allowedRoles.includes(r.id)?'selected':''}>${r.name}</option>`).join('')}</select></label><label>Denied Roles<select multiple name="${c.name}.deniedRoles">${resources.roles.map(r=>`<option value="${r.id}" ${s.deniedRoles.includes(r.id)?'selected':''}>${r.name}</option>`).join('')}</select></label><label>Allowed Channels<select multiple name="${c.name}.allowedChannels">${resources.channels.map(r=>`<option value="${r.id}" ${s.allowedChannels.includes(r.id)?'selected':''}>#${r.name}</option>`).join('')}</select></label><label>Denied Channels<select multiple name="${c.name}.deniedChannels">${resources.channels.map(r=>`<option value="${r.id}" ${s.deniedChannels.includes(r.id)?'selected':''}>#${r.name}</option>`).join('')}</select></label></details></article>`}).join('')}</form><div class="savebar"><span>لديك تغييرات غير محفوظة</span><button data-reset>Reset</button><button data-save-commands>Save changes</button></div>`; %><%- include('layout',{body,commands:true}) %>
