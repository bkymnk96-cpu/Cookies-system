<% const names={welcome:'الترحيب ومحرر الصورة',tickets:'التذاكر',applications:'التقديمات',protection:'الحماية',logs:'السجلات',autoReply:'الردود التلقائية',suggestions:'الاقتراحات',feedback:'الآراء والتقييم',giveaways:'القيف أواي',autoLine:'الخط التلقائي',tax:'الضريبة',broadcast:'البرودكاست',activity:'النشاط والتوب',adminPoints:'نقاط الإدارة',settings:'الإعدادات العامة'}; %><%- include('layout',{module,body:`<header class="page"><p>ZEUS / ${module}</p><h1>${names[module]||module}</h1><span>تقرأ وتحفظ إعدادات ${module} تحت Guild ID الحالي مع تحديث كاش البوت.</span></header><form id="moduleForm" class="config-form" data-module="${module}"><section class="card"><div class="row"><h2>General</h2><label class="switch"><input name="enabled" type="checkbox" ${config.enabled?'checked':''}><span></span></label></div><div class="form-grid"><label>Channel<select name="channelId"><option value="">None</option>${resources.channels.map(c=>`<option value="${c.id}" ${config.channelId===c.id?'selected':''}>#${c.name}</option>`).join('')}</select></label><label>Log Channel<select name="logChannel"><option value="">None</option>${resources.channels.map(c=>`<option value="${c.id}" ${config.logChannel===c.id?'selected':''}>#${c.name}</option>`).join('')}</select></label><label>Role<select name="roleId"><option value="">None</option>${resources.roles.map(r=>`<option value="${r.id}" ${config.roleId===r.id?'selected':''}>${r.name}</option>`).join('')}</select></label><label>Color<input type="color" name="color" value="${config.color||'#5865f2'}"></label><label>Mode<select name="mode"><option value="embed">Embed</option><option value="text">Text</option><option value="image">Image</option><option value="link">Link</option></select></label><label>Cooldown<input type="number" name="cooldown" value="${config.cooldown||0}"></label></div></section><section class="card"><h2>Messages / Embed</h2><label>Title<input name="title" value="${config.title||''}"></label><label>Message<textarea name="message">${config.message||''}</textarea></label><label>DM Message<textarea name="dmMessage">${config.dmMessage||''}</textarea></label><label>Footer<input name="footer" value="${config.footer||''}"></label><label>Image URL<input name="image" value="${config.image||''}"></label><label>Line URL<input name="line" value="${config.line||''}"></label></section>${module==='welcome'?`<section class="card"><h2>محرر صورة الترحيب</h2><div class="welcome-editor" id="welcomeEditor"><div class="preview" id="welcomePreview"><img class="bg" src="${config.imageEditor?.backgroundUrl||''}"><div class="avatar" style="left:${config.imageEditor?.avatar?.x||420}px;top:${config.imageEditor?.avatar?.y||140}px;width:${config.imageEditor?.avatar?.size||168}px;height:${config.imageEditor?.avatar?.size||168}px;border:${config.imageEditor?.avatar?.borderWidth||6}px solid ${config.imageEditor?.avatar?.borderColor||'#fff'};border-radius:${config.imageEditor?.avatar?.borderRadius||50}%"></div></div><div class="form-grid"><label>Background URL<input name="imageEditor.backgroundUrl" value="${config.imageEditor?.backgroundUrl||''}"></label><label>Zoom<input type="range" name="imageEditor.avatar.zoom" min=".5" max="3" step=".1" value="${config.imageEditor?.avatar?.zoom||1}"></label><label>Size<input type="range" name="imageEditor.avatar.size" min="64" max="320" value="${config.imageEditor?.avatar?.size||168}"></label><label>Border Radius<input type="range" name="imageEditor.avatar.borderRadius" min="0" max="50" value="${config.imageEditor?.avatar?.borderRadius||50}"></label><label>Border Width<input type="range" name="imageEditor.avatar.borderWidth" min="0" max="20" value="${config.imageEditor?.avatar?.borderWidth||6}"></label><label>Border Color<input type="color" name="imageEditor.avatar.borderColor" value="${config.imageEditor?.avatar?.borderColor||'#ffffff'}"></label><input type="hidden" name="imageEditor.avatar.x" value="${config.imageEditor?.avatar?.x||420}"><input type="hidden" name="imageEditor.avatar.y" value="${config.imageEditor?.avatar?.y||140}"><button type="button" data-center-avatar>Center Image</button></div><div class="vars">${['member','user','tag','user_id','server','server_id','member_count','inviter','invite_code','invite_uses','created_at','joined_at'].map(v=>`<button type="button" data-copy="{${v}}">{${v}}</button>`).join('')}</div></section>`:''}<section class="card"><h2>Advanced JSON</h2><p>للأنظمة ذات القوائم مثل أقسام التذاكر، أسئلة التقديم، ردود Auto Reply، أحداث Logs، وتوكنات Broadcast المقنّعة.</p><textarea name="__json" class="jsonbox">${JSON.stringify(config,null,2)}</textarea></section></form><div class="savebar"><span>تغييرات غير محفوظة</span><button data-reset>Reset</button><button data-save-module>Save changes</button></div>`}) %>
